# Voice-to-Cursor configuration template.
# Copy this file to `.env` and uncomment/adjust values as needed.

# Hotkey & interaction
# HOTKEY=f9
# PUSH_TO_TALK=true

# Audio capture
# AUDIO_SAMPLE_RATE=16000
# AUDIO_CHANNELS=1
# AUDIO_MAX_RECORD_SECONDS=60.0

# ASR
# ASR_MODEL=base
# ASR_LANGUAGE=auto
# ASR_DEVICE=cpu
# ASR_COMPUTE_TYPE=int8
# ASR_BEAM_SIZE=5
# ASR_STREAMING_BEAM_SIZE=1
# ASR_WARMUP_AT_START=true

# Streaming
# STREAMING_ENABLED=false
# STREAMING_CHUNK_SECONDS=1.0

# Final background transcription
# FINAL_TRANSCRIPTION_ENABLED=true
# REPLACE_STREAMING_WITH_FINAL=false

# LLM post-processing
# LLM_ENABLED=false
# LLM_URL=http://localhost:11434
# LLM_MODEL=llama3
# LLM_TIMEOUT=5.0
# LLM_PROMPT="You are a helpful assistant. Fix grammar, punctuation, and formatting of the user's text. Keep the original language. Do not add explanations. Return only the improved text."

# Text injection
# INJECTION_DELAY_MS=0.0
# INJECTION_FALLBACK_TO_CLIPBOARD=false

# Voice activity detection
# VAD_AGGRESSIVENESS=1
# VAD_TRIM_SECONDS=0.3

# Dry-run mode (print instead of injecting)
# DRY_RUN=false

# Dictionary / vocabulary
# CONTEXT_MODE=general
# DICTIONARY_ENABLED=true
# DICTIONARY_LEARNING_ENABLED=false
# VOCAB_DIR=data/vocab

# Paths
# DATA_DIR=data
# MODELS_DIR=models

# Logging
# LOG_LEVEL=INFO
